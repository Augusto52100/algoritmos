programa {
  funcao inicio() {
    inteiro n1
    escreva ("diga sua idade")
    leia (n1)

    se (n1>=14){

    escreva("filme permitido = classificação adulta")
    }
    senao se ((n1>=10) e (n1<14)){

    escreva ("filme permitido = classificação juvenil")
    }

    senao {

    escreva ("filme permitido = classificação livre")
    }
  
 }
}
